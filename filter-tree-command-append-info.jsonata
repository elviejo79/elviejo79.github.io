(
    $processDir := function($dir) {
      $dir.{
        "type": type,
        "name": name,
        "time": contents[name="index.html"].time,
        "info": contents[name="index.html"].info,
        "thumbnail": contents[name="images"].contents[name="thumbnail.png"].name,
        "contents": contents[type="directory"].($processDir($))
      }
    };
    
    /* the name:$ is the thing that names the objects as the subdirectory they contain*/
    $processDir($.contents){name:$}; 
  )
