<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>Alejandro Garcia's Blog</title>
<link href="https://cdn.jsdelivr.net/npm/tufte-css/tufte.min.css" rel="stylesheet">
</head>

<body>
  <article>
    <h1 id="name">Alejandro Garcia</h1>
    <p class="subtitle">Writer, Developer, and Entrepreneur</p>

    <section>
      <h2 id="writes">Writes</h2>

      {{#writes.contents}}
      <h3>  {{#time}}{{time}}{{/time}}: <a href="./writes/{{name}}/">{{name}}</a></h3>
      {{#info}}
      <p>{{#thumbnail}}
      <label for="mn-{{time}}" class="margin-toggle">&#8853;</label>
      <input type="checkbox" id="mn-{{time}}" class="margin-toggle"/>
      <span class="marginnote">
        <img src="./writes/{{name}}/images/{{thumbnail}}"/>
      </span>
      {{/thumbnail}}</p>
      <p>{{& info}}</p>{{/info}}
      {{/writes.contents}}
    </section>

    <section>
      <h2>About</h2>
{{#About.contents}}
      <h3> <a href="./pages/{{name}}/">{{name}}</a></h3>
      {{#info}}<p>{{& info}}</p>{{/info}}
{{/About.contents}}
</section>

</article>

<hr/>
<div id="footer">
<p></p>
</div>

</div>
</body>
</html>
